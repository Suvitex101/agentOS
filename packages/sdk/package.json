{
  "name": "@agentosdev/sdk",
  "version": "0.1.0-alpha.1",
  "description": "Primary public SDK entry point for AgentOS.",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Suvitex101/agentOS.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/Suvitex101/agentOS#readme",
  "bugs": {
    "url": "https://github.com/Suvitex101/agentOS/issues"
  },
  "keywords": [
    "agentos",
    "sdk",
    "ai-agents",
    "agent-infrastructure",
    "typescript"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@agentosdev/connectors": "workspace:^",
    "@agentosdev/core": "workspace:^",
    "@agentosdev/memory": "workspace:^",
    "@agentosdev/providers": "workspace:^",
    "@agentosdev/types": "workspace:^"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../scripts/fix-esm-extensions.mjs dist",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.7"
  }
}
