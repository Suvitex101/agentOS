{
  "name": "@agentos/connectors",
  "version": "0.1.0-alpha.1",
  "description": "Local connector implementations for AgentOS.",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Suvitex101/agaentOS.git",
    "directory": "packages/connectors"
  },
  "homepage": "https://github.com/Suvitex101/agaentOS#readme",
  "bugs": {
    "url": "https://github.com/Suvitex101/agaentOS/issues"
  },
  "keywords": [
    "agentos",
    "connectors",
    "filesystem",
    "http",
    "typescript"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../scripts/fix-esm-extensions.mjs dist",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agentos/core": "workspace:^",
    "@agentos/types": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^22.10.7"
  }
}
