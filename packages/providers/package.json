{
  "name": "@agentosdev/providers",
  "version": "0.1.0-alpha.1",
  "description": "Model provider foundation, OpenAI-compatible adapter, and Ollama provider for AgentOS.",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Suvitex101/agentOS.git",
    "directory": "packages/providers"
  },
  "homepage": "https://github.com/Suvitex101/agentOS#readme",
  "bugs": {
    "url": "https://github.com/Suvitex101/agentOS/issues"
  },
  "keywords": [
    "agentos",
    "model-provider",
    "reasoning",
    "ollama",
    "openai-compatible",
    "typescript"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../scripts/fix-esm-extensions.mjs dist",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agentosdev/core": "workspace:^",
    "@agentosdev/types": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^22.10.7"
  }
}
