{
  "name": "@agentosdev/config",
  "version": "0.1.0-alpha.1",
  "private": true,
  "description": "Internal shared development configuration for AgentOS.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./tsconfig/base": "./tsconfig/base.json",
    "./tsconfig/next": "./tsconfig/next.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../scripts/fix-esm-extensions.mjs dist",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
